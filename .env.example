# Create a Discord application at https://discord.com/developers/applications
# Add http://localhost:3000/api/auth/discord/callback as its redirect URI for local development.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Use a long random value. For example: openssl rand -base64 32
AUTH_SECRET=

# Database connection string for PostgreSQL.
# Replace with your actual database URL.
DATABASE_URL=postgresql://username:password@host:5432/database_name

# Optional: set this if you want to use the default Next.js port locally.
# PORT=3000
